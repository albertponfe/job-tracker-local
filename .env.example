# ─────────────────────────────────────────────────────────────
#  Optional configuration. You do NOT need this file to run the app.
#  Everything here can also be set inside the app's Settings panel.
#  To use it: copy this file to ".env" and edit the values.
# ─────────────────────────────────────────────────────────────

# Port the local server runs on (default 3000)
# PORT=3000

# Set to "1" to stop the app from auto-opening your browser on start
# NO_OPEN=0

# ── AI extraction (all optional) ──
# The app works fully without AI — this only powers the "Extract" button
# that auto-fills a job's details from its URL. You can also configure all
# of this in Settings → AI, which is easier. Choose ONE provider:
#
#   none              -> no AI (manual entry only)
#   ollama            -> free local model (install from https://ollama.com)
#   openai-compatible -> OpenAI, OpenRouter, LM Studio, Groq, etc. (needs a key/base URL)
#   anthropic         -> Anthropic Claude (needs a key)
#
# AI_PROVIDER=none
# AI_MODEL=llama3.2
# AI_BASE_URL=http://localhost:11434
# AI_API_KEY=
