# ─────────────────────────────────────────────────────────────
#  Optional configuration. You do NOT need this file to run the app.
#  These are examples for setting environment variables in your shell or
#  launcher before starting Queue; the app does not load .env files itself.
# ─────────────────────────────────────────────────────────────

# Port the local server runs on (default 3000)
# PORT=3000

# Set to "1" to stop the app from auto-opening your browser on start
# NO_OPEN=0

# ── AI extraction (all optional) ──
# The app works fully without AI — this only powers the "Extract" button
# that auto-fills a job's details from unsupported URLs. AI settings can also
# be configured from the AI button in Queue. Choose ONE provider:
#
#   none              -> built-in extraction only; no AI
#   ollama            -> free local model (install from https://ollama.com)
#   openai            -> OpenAI (needs a key)
#   anthropic         -> Anthropic Claude (needs a key)
#
# AI_PROVIDER=none
# AI_MODEL=llama3.2
# AI_BASE_URL=http://localhost:11434
# AI_API_KEY=
